rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔓 Publicly readable collections
    match /public/{document=**} {
      allow read: if true;
    }

    match /categories/{categoryId} {
      allow read: if true;
    }

    match /cities/{cityId} {
      allow read: if true;
    }

    // 👤 USERS (CUSTOMERS)
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 👥 WORKERS
    match /workers/{workerId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == workerId;

      // Reviews for workers
      match /reviews/{reviewId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;

        // Optional: only review author can update/delete
        // allow update, delete: if request.auth.uid == resource.data.authorId;
      }
    }

    // 👤 CUSTOMERS (if you store separate collection)
    match /customers/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 📦 TASKS COLLECTION
    match /tasks/{taskId} {

      allow read: if request.auth != null;

      // ✅ Only customers can create tasks
      allow create: if isCustomer();

      // ✅ Only the customer who created the task can update/delete
      allow update, delete: if request.auth != null &&
                            request.auth.uid == resource.data.customerId;

      // ✅ Optionally: allow a worker to accept the task
      allow update: if isWorker() && canAcceptTask();
    }

    // ✅ Functions

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isCustomer() {
      return isSignedIn() && userDoc().role == 'customer';
    }

    function isWorker() {
      return isSignedIn() && userDoc().role == 'worker';
    }

    function canAcceptTask() {
      return resource.data.status == 'pending' &&
             request.resource.data.status == 'accepted' &&
             request.resource.data.workerId == request.auth.uid;
    }
  }
}

